# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# S3-compatible storage for M2 publishing (Cloudflare R2 recommended)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zonecast
R2_PUBLIC_BASE_URL=

# Optional: web search enrichment for `--research` (leave empty to disable)
SEARCH_API_KEY=
